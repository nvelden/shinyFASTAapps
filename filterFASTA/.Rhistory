queryDF_to_dplyr <- function(queryDF){
dplyr_query <- NULL
columns <- queryDF$columns
operators <- queryDF$operators
inputs <- queryDF$inputs
for(i in 1:length(columns)){
if(operators[i] == "None"){
dplyr_query <- sprintf('filter(str_detect(%s, "%s")',
columns[i],
inputs[i])
} else if(operators[i] == "AND"){
dplyr_query <- paste0(dplyr_query,
sprintf(' & str_detect(%s, "%s")',
columns[i],
inputs[i])
)
} else if(operators[i] == "NOT"){
dplyr_query <- paste0(dplyr_query,
sprintf(' & !str_detect(%s, "%s")',
columns[i],
inputs[i])
)
} else if(operators[i] == "OR"){
dplyr_query <- paste0(dplyr_query,
sprintf(' | str_detect(%s, "%s")',
columns[i],
inputs[i])
)
}
}
dplyr_query <- paste0(dplyr_query, ")")
return(dplyr_query)
}
queryDF_to_dplyr(queryDF)
