#Make a DF of all reactive inputs
inputs_to_DF <- function(inputs){
x <- reactiveValuesToList(inputs)
names <- names(x)
#Replace NULL values with NA
x[sapply(x, is.null)] <- NA
data.frame(
names = names(x),
values = unlist(x, use.names = FALSE)
)
}
